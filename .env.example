# Required: the exact HTTPS address entered in Lore Desktop.
# This one value is also used as the JWT issuer and to derive the TLS hostname.
LORE_AUTH_URL=https://auth.example.com:10443

# Required only on the first start; it creates the root administrator account.
LORE_AUTH_PASSWORD=replace-with-a-long-random-password

# Optional: enables repository management in the administration page.
LORE_SERVER_URL=http://192.168.1.10:41337

# manual: use /certs/server.pem and /certs/server.key
# auto: let Caddy obtain a certificate for the hostname in LORE_AUTH_URL
LORE_AUTH_TLS_MODE=manual

# Compose host settings (these are not passed into the container).
LORE_AUTH_DATA_DIR=./data
CADDY_CERTS_DIR=./certs
LORE_AUTH_HTTPS_PORT=10443
